{
  "name": "ghost-compute",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "orchestrator": "tsx --env-file=.env apps/web/src/server/orchestrator/server.ts",
    "worker:dev": "tsx --env-file=.env worker/src/index.ts",
    "anchor:build": "anchor build",
    "deploy:programs": "tsx --env-file=.env scripts/deploy-programs.ts",
    "launch:ghst": "tsx --env-file=.env scripts/launch-ghst-pump.ts",
    "sync:idls": "tsx scripts/sync-idls.ts",
    "test:x402": "tsx --env-file=.env scripts/test-x402-inference.ts",
    "test:x402:settlement": "tsx --env-file=.env scripts/test-x402-settlement.ts",
    "test:x402:client": "tsx --env-file=.env scripts/test-x402-client-settlement.ts",
    "example:ghost-client": "tsx --env-file=.env scripts/example-ghost-openai-client.ts",
    "test:chain-indexer": "tsx --env-file=.env scripts/test-chain-indexer.ts",
    "test:darkpool-onchain": "tsx --env-file=.env scripts/test-dark-pool-onchain.ts",
    "test:worker-registry": "tsx --env-file=.env scripts/test-worker-registry-onchain.ts",
    "test:sealed-darkpool": "tsx --env-file=.env scripts/test-sealed-darkpool-onchain.ts",
    "test:attestation": "tsx --env-file=.env scripts/test-attestation.ts",
    "setup:fee-ata": "tsx --env-file=.env scripts/setup-fee-vault-ata.ts",
    "setup:fee-distribution": "tsx --env-file=.env scripts/setup-fee-distribution.ts",
    "distribute:fees": "tsx --env-file=.env scripts/distribute-fees.ts",
    "migrate:x402": "tsx --env-file=.env scripts/migrate-x402-settlements.ts",
    "migrate:chain-events": "tsx --env-file=.env scripts/migrate-chain-events.ts",
    "apply:supabase-migrations": "tsx --env-file=.env scripts/apply-supabase-migrations.ts",
    "build:dashboard-x402": "node apps/web/scripts/build-dashboard-x402.mjs",
    "verify:stack": "tsx --env-file=.env scripts/verify-stack.ts",
    "test:solana": "tsx --env-file=.env scripts/test-solana-clients.ts",
    "solana:setup": "tsx --env-file=.env -e \"import { syncDevWalletFile, loadDevWallet } from './scripts/solana-lib.ts'; syncDevWalletFile(); console.log(loadDevWallet().publicKey.toBase58())\"",
    "ghost-worker:dev": "pnpm --dir apps/ghost-worker tauri:dev",
    "ghost-worker:build": "pnpm --dir apps/ghost-worker tauri:build",
    "ghost-worker:prepare": "pnpm --dir apps/ghost-worker prepare:daemon",
    "ghost-worker:prepare:vllm": "pnpm --dir apps/ghost-worker prepare:vllm"
  },
